{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "respectGitignore": true,
  "env": {
    "EDITOR": "nvim"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(ls *)",
      "Bash(command ls *)",
      "Bash(/bin/ls *)",
      "Bash(find *)",
      "Bash(command find *)",
      "Bash(/bin/find *)",
      "Bash(grep *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(git status *)",
      "Bash(git * status *)",
      "Bash(git log *)",
      "Bash(git * log *)",
      "Bash(git diff *)",
      "Bash(git * diff *)",
      "Bash(git show *)",
      "Bash(git * show *)",
      "Bash(git fetch *)",
      "Bash(git * fetch *)",
      "Bash(git branch *)",
      "Bash(git * branch *)",
      "Bash(git add *)",
      "Bash(git * add *)",
      "Bash(git remote *)",
      "Bash(git * remote *)",
      "Bash(gh pr view *)",
      "Bash(gh pr list *)",
      "Bash(gh issue view *)",
      "Bash(gh issue list *)",
      "Bash(gh repo view *)",
      "WebSearch",
      "WebFetch",
      "mcp__plugin_context7_context7",
      "mcp__github__list_pull_requests",
      "mcp__github__pull_request_read"
    ],
    "deny": [
      "Read(//**/.env)",
      "Read(//**/.env.*)"
    ],
    "ask": [
      "Bash(git commit *)"
    ],
    "additionalDirectories": [
      "~"
    ]
  },
  "model": "opus[1m]",
  "enabledMcpjsonServers": [
    "github"
  ],
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": false,
    "context7@claude-plugins-official": true,
    "notion@claude-plugins-official": true
  },
  "effortLevel": "medium",
  "voiceEnabled": true,
  "voice": {
    "enabled": true,
    "mode": "hold"
  }
}
